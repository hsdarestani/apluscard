DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=cards.smarbiz.sbs,91.107.145.196,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://cards.smarbiz.sbs
DJANGO_TIME_ZONE=Europe/Berlin
DJANGO_SECURE_COOKIES=1
DJANGO_HSTS_SECONDS=0
DEFAULT_BUSINESS_SLUG=shisha-bar
DATABASE_URL=postgresql://apluscard:replace-db-password@db:5432/apluscard
POSTGRES_DB=apluscard
POSTGRES_USER=apluscard
POSTGRES_PASSWORD=replace-db-password

APP_NAME=SAMS Card
APP_SHORT_NAME=SAMS
APP_PUBLISHER=A+ Solution GmbH
APP_SUPPORT_EMAIL=app@aplus-solution.de
APP_PUBLIC_BASE_URL=https://cards.smarbiz.sbs
ANDROID_PACKAGE_NAME=de.aplussolution.samscard
ANDROID_APP_SIGNING_SHA256=
IOS_BUNDLE_ID=de.aplussolution.samscard
IOS_APP_TEAM_ID=XXXXXXXXXX

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.strato.de
EMAIL_PORT=465
EMAIL_HOST_USER=app@aplus-solution.de
EMAIL_HOST_PASSWORD=replace-mailbox-password
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=SAMS Card <app@aplus-solution.de>
SERVER_EMAIL=SAMS Card System <app@aplus-solution.de>
EMAIL_REPLY_TO=app@aplus-solution.de

# Native Push Notifications
PUSH_NOTIFICATIONS_ENABLED=0
PUSH_HTTP_TIMEOUT_SECONDS=10
PUSH_NOTIFICATION_MAX_AGE_SECONDS=21600
PUSH_MAX_ATTEMPTS=5

# Android: Firebase Cloud Messaging service account JSON, Base64 encoded.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# iOS: Apple Push Notification service authentication key (.p8), Base64 encoded.
APNS_KEY_ID=
APNS_TEAM_ID=XXXXXXXXXX
APNS_PRIVATE_KEY_BASE64=
APNS_USE_SANDBOX=0

APPLE_CLIENT_ID=de.example.web
APPLE_KEY_ID=XXXXXXXXXX
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY_BASE64=base64-encoded-p8-content
APPLE_REDIRECT_URI=https://cards.smarbiz.sbs/accounts/apple/callback/
APPLE_WALLET_PASS_TYPE_ID=pass.de.example.sams.member
APPLE_WALLET_TEAM_ID=XXXXXXXXXX
APPLE_WALLET_P12_BASE64=base64-encoded-pass-type-certificate-p12
APPLE_WALLET_P12_PASSWORD=certificate-export-password
APPLE_WALLET_WWDR_CERT_BASE64=base64-encoded-apple-wwdr-certificate
