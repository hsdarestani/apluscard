{
  "name": "sams-card-mobile",
  "private": true,
  "version": "1.0.1",
  "description": "Native iOS and Android shell for SAMS Card",
  "scripts": {
    "sync": "npx cap sync",
    "android": "npx cap open android",
    "ios": "npx cap open ios",
    "doctor": "npx cap doctor",
    "assets:android": "npx @capacitor/assets generate --android --assetPath assets --iconBackgroundColor '#09050f' --iconBackgroundColorDark '#09050f' --splashBackgroundColor '#09050f' --splashBackgroundColorDark '#09050f'",
    "assets:ios": "npx @capacitor/assets generate --ios --assetPath assets --iconBackgroundColor '#09050f' --iconBackgroundColorDark '#09050f' --splashBackgroundColor '#09050f' --splashBackgroundColorDark '#09050f'"
  },
  "dependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/core": "8.4.2",
    "@capacitor/ios": "8.4.2",
    "@capacitor/push-notifications": "8.1.2"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.4.2",
    "typescript": "5.9.3"
  }
}
